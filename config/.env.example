# Market Intelligence Agent — Environment Variables
# Copy this file to .env and fill in your values

# ── LLM API Keys (at least one required) ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# ── Claude Model (default: claude-opus-4-8) ──────────────────────────────────
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# ── Ollama (optional, for offline/privacy mode) ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Privacy Mode: set to 1 to force all LLM calls through Ollama ─────────────
PRIVACY_MODE=0

# ── HuggingFace (required for downloading models from Hub) ───────────────────
HF_TOKEN=your_huggingface_token_here

# ── Data directories ──────────────────────────────────────────────────────────
DATA_DIR=./data
MODELS_DIR=./models
OUTPUT_DIR=./output

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8007
LOG_LEVEL=INFO

# ── Optional: World Bank API (free, no key required; but key increases rate limits)
# WORLD_BANK_API_KEY=your_world_bank_key_here

# ── Optional: Semantic Scholar API Key (free tier works without key)
# S2_API_KEY=your_s2_key_here

# ── Optional: GitHub token for knowledge updater GitHub release fetching
# GITHUB_TOKEN=your_github_token_here
